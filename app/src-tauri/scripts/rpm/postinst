#!/bin/bash
# postinst-rpm - RPM package post-install script.
# In RPM, $1 is the number of installed versions after the transaction.

set -e

# Refresh linker cache after installing the private Biopass library path.
ldconfig

# Run the model downloader for the installing user.
SCRIPT="/usr/share/com.ticklab.biopass/download_models.sh"
if [ -f "$SCRIPT" ]; then
    echo "Biopass: Running model downloader..."
    bash "$SCRIPT" || true
fi

exit 0
